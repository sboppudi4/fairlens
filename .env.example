# Backend
DATABASE_URL=postgresql+asyncpg://fairlens:fairlens@postgres:5432/fairlens
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-to-a-64-char-random-string-in-production-please-do-not-reuse
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
